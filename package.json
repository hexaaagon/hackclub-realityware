{
  "name": "realityware",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "biome format --write",
    "lint": "biome check",
    "biome:lint": "biome check",
    "biome:format": "biome format --write",
    "db:generate": "bun run db:generate:auth && bun run db:generate:migrations",
    "db:generate:auth": "bunx @better-auth/cli generate --config ./src/lib/auth/index.ts --output ./src/lib/db/schema/auth.ts -y",
    "db:generate:migrations": "drizzle-kit generate",
    "db:migrate": "bun src/lib/db/migrate.ts",
    "db:drop": "drizzle-kit drop",
    "db:pull": "drizzle-kit introspect",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "preinstall": "npx only-allow bun",
    "postinstall": "bun db:migrate"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.0",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookies-next": "^6.1.1",
    "drizzle-orm": "^0.45.1",
    "easy-peasy": "^6.1.0",
    "geist": "^1.7.0",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.6",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "postgres": "^3.4.8",
    "posthog-js": "^1.360.0",
    "posthog-node": "^5.28.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.9",
    "react-scan": "^0.5.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5"
  }
}
