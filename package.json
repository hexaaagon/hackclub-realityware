{
  "name": "realityware",
  "private": true,
  "scripts": {
    "start": "turbo run start",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "preinstall": "npx only-allow bun",
    "postinstall": "turbo run postinstall"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/rpc/*",
    "packages/*"
  ],
  "overrides": {
    "typescript": "6.0.3"
  }
}
